{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Build DLL only",
      "type": "cppdbg",
      "request": "launch",
      "program": "C:/Windows/System32/cmd.exe",
      "args": [
        "/c",
        "echo DLL zbudowana!"
      ],
      "preLaunchTask": "Build OpenGL DLL",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "d:/projekty/robot_simulator",
      "program": "d:/projekty/robot_simulator/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}